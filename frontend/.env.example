# Vite Environment Variables
# These variables are exposed to the client-side code

# API Configuration
VITE_API_URL=http://localhost:5000/api
VITE_API_TIMEOUT=30000

# App Configuration
VITE_APP_NAME=CraftLens AI
VITE_APP_ENV=development
VITE_ENABLE_ANALYTICS=true

# Note: Only variables prefixed with VITE_ are exposed to the browser
# For sensitive data, keep it on the server only and fetch via API
